generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DELEGATE
}

enum DelegateStatus {
  EN_VISITE
  EN_DEPLACEMENT
  EN_PAUSE
  INACTIF
}

enum SalesReportStatus {
  DRAFT
  SUBMITTED
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  password         String
  firstName        String
  lastName         String
  role             Role             @default(DELEGATE)
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdById      String?
  createdBy        User?            @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers     User[]           @relation("UserCreator")
  adminLabs        AdminLaboratory[]
  delegate         Delegate?
  activeSessions   ActiveSession[]
  loginHistory     LoginHistory[]
  salesReports     SalesReport[]
  sentMessages     Message[]        @relation("SentMessages")
  receivedMessages Message[]        @relation("ReceivedMessages")
}

model ActiveSession {
  id         String   @id @default(cuid())
  userId     String   @unique
  token      String
  deviceInfo String?
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  deviceInfo String?
  ipAddress  String?
  success    Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages",     fields: [senderId],   references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Laboratory {
  id           String                @id @default(cuid())
  name         String                @unique
  createdAt    DateTime              @default(now())
  admins       AdminLaboratory[]
  grossLabs    GrossisteLaboratory[]
  delegates    Delegate[]
  reports      VisitReport[]
  salesReports SalesReport[]
}

model AdminLaboratory {
  userId       String
  laboratoryId String
  user         User       @relation(fields: [userId],       references: [id], onDelete: Cascade)
  laboratory   Laboratory @relation(fields: [laboratoryId], references: [id])
  @@id([userId, laboratoryId])
}

model Grossiste {
  id         String                @id @default(cuid())
  name       String                @unique
  createdAt  DateTime              @default(now())
  labs       GrossisteLaboratory[]
  pharmacies Pharmacy[]
}

model GrossisteLaboratory {
  grossisteId  String
  laboratoryId String
  grossiste    Grossiste  @relation(fields: [grossisteId],  references: [id])
  laboratory   Laboratory @relation(fields: [laboratoryId], references: [id])
  updatedAt    DateTime   @updatedAt
  updatedById  String?
  stocks       GrossisteStock[]
  @@id([grossisteId, laboratoryId])
}

model GrossisteStock {
  id           String              @id @default(cuid())
  grossisteId  String
  laboratoryId String
  productName  String
  quantity     Int                 @default(0)
  unitPrice    Float               @default(0)
  month        String
  updatedAt    DateTime            @updatedAt
  grossisteLab GrossisteLaboratory @relation(fields: [grossisteId, laboratoryId], references: [grossisteId, laboratoryId])
}

model Pharmacy {
  id           String        @id @default(cuid())
  grossisteId  String?
  codeClient   String?
  nom          String
  pharmacien   String?
  adresse      String?
  ville        String?
  region       String?
  province     String?
  telephone    String?
  email        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  grossiste    Grossiste?    @relation(fields: [grossisteId], references: [id])
  visitReports VisitReport[]
  @@unique([grossisteId, codeClient])
}

model Sector {
  id            String     @id @default(cuid())
  numero        Int
  delegateName  String?
  zoneResidence String
  peripherie    String?
  axesMission   String?
  type          String
  createdAt     DateTime   @default(now())
  delegates     Delegate[]
}

model Delegate {
  id           String         @id @default(cuid())
  userId       String         @unique
  laboratoryId String
  sectorId     String?
  zone         String
  phone        String?
  status       DelegateStatus @default(INACTIF)
  lastLat      Float?
  lastLng      Float?
  lastSeen     DateTime?
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId],       references: [id], onDelete: Cascade)
  laboratory   Laboratory     @relation(fields: [laboratoryId], references: [id])
  sector       Sector?        @relation(fields: [sectorId],     references: [id])
  gpsLogs      GPSLog[]
  visitReports VisitReport[]
  planning     WeeklyPlanning[]
}

model GPSLog {
  id         String         @id @default(cuid())
  delegateId String
  latitude   Float
  longitude  Float
  status     DelegateStatus
  timestamp  DateTime       @default(now())
  delegate   Delegate       @relation(fields: [delegateId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(cuid())
  name        String   @unique
  group       String
  specialty   String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model WeeklyPlanning {
  id         String   @id @default(cuid())
  delegateId String
  weekNumber Int
  zone       String
  lundi      String?
  mardi      String?
  mercredi   String?
  jeudi      String?
  vendredi   String?
  month      String
  createdAt  DateTime @default(now())
  delegate   Delegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)
}

model VisitReport {
  id            String     @id @default(cuid())
  delegateId    String
  laboratoryId  String
  pharmacyId    String?
  doctorName    String
  specialty     String?
  productsShown String?
  notes         String
  aiSummary     String?
  visitDate     DateTime   @default(now())
  createdAt     DateTime   @default(now())
  delegate      Delegate   @relation(fields: [delegateId],   references: [id])
  laboratory    Laboratory @relation(fields: [laboratoryId], references: [id])
  pharmacy      Pharmacy?  @relation(fields: [pharmacyId],   references: [id])
}

model SalesReport {
  id           String            @id @default(cuid())
  adminId      String
  laboratoryId String
  month        String
  year         Int
  status       SalesReportStatus @default(DRAFT)
  submittedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  admin        User              @relation(fields: [adminId],      references: [id])
  laboratory   Laboratory        @relation(fields: [laboratoryId], references: [id])
  lines        SalesReportLine[]
}

model SalesReportLine {
  id             String      @id @default(cuid())
  reportId       String
  itemNumber     Int
  designation    String
  pght           Float       @default(0)
  copharmedStock Float       @default(0)
  copharmedVente Float       @default(0)
  copharmedS     Float       @default(0)
  copharmedV     Float       @default(0)
  laborexStock   Float       @default(0)
  laborexVente   Float       @default(0)
  laborexS       Float       @default(0)
  laborexV       Float       @default(0)
  tedisStock     Float       @default(0)
  tedisVente     Float       @default(0)
  tedisS         Float       @default(0)
  tedisV         Float       @default(0)
  dpciStock      Float       @default(0)
  dpciVente      Float       @default(0)
  dpciS          Float       @default(0)
  dpciV          Float       @default(0)
  report         SalesReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}