generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ─────────────────────────────────────────────────────
enum Role {
  SUPER_ADMIN
  ADMIN
  DELEGATE
}

enum DelegateStatus {
  EN_VISITE
  EN_DEPLACEMENT
  EN_PAUSE
  INACTIF
}

// ─── UTILISATEURS ──────────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  email       String   @unique @db.VarChar(255)
  password    String   @db.VarChar(255)
  firstName   String   @db.VarChar(100)
  lastName    String   @db.VarChar(100)
  role        Role     @default(DELEGATE)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?  @db.VarChar(30)

  createdBy    User?             @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers User[]            @relation("UserCreator")
  adminLabs    AdminLaboratory[]
  delegate     Delegate?
}

// ─── LABORATOIRES ──────────────────────────────────────────────
// lic-pharma | medisure | sigma | ephaco | stallion
model Laboratory {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())

  admins    AdminLaboratory[]
  grossLabs GrossisteLaboratory[]
  delegates Delegate[]
  reports   VisitReport[]
}

model AdminLaboratory {
  userId       String @db.VarChar(30)
  laboratoryId String @db.VarChar(30)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  laboratory Laboratory @relation(fields: [laboratoryId], references: [id])

  @@id([userId, laboratoryId])
}

// ─── GROSSISTES ────────────────────────────────────────────────
// tedis | copharmed | laborex | dpci
model Grossiste {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())

  labs       GrossisteLaboratory[]
  pharmacies Pharmacy[]
}

model GrossisteLaboratory {
  grossisteId  String @db.VarChar(30)
  laboratoryId String @db.VarChar(30)

  grossiste   Grossiste  @relation(fields: [grossisteId], references: [id])
  laboratory  Laboratory @relation(fields: [laboratoryId], references: [id])
  updatedAt   DateTime   @updatedAt
  updatedById String?    @db.VarChar(30)

  stocks GrossisteStock[]

  @@id([grossisteId, laboratoryId])
}

model GrossisteStock {
  id           String   @id @default(cuid())
  grossisteId  String   @db.VarChar(30)
  laboratoryId String   @db.VarChar(30)
  productName  String   @db.VarChar(200)
  quantity     Int      @default(0)
  unitPrice    Float    @default(0)
  month        String   @db.VarChar(10)
  updatedAt    DateTime @updatedAt

  grossisteLab GrossisteLaboratory @relation(fields: [grossisteId, laboratoryId], references: [grossisteId, laboratoryId])
}

// ─── PHARMACIES ────────────────────────────────────────────────
// Importées depuis vos 4 fichiers Excel grossistes
model Pharmacy {
  id          String   @id @default(cuid())
  grossisteId String?  @db.VarChar(30)
  codeClient  String?  @db.VarChar(50)
  nom         String   @db.VarChar(255)
  pharmacien  String?  @db.VarChar(255)
  adresse     String?  @db.VarChar(255)
  ville       String?  @db.VarChar(150)
  region      String?  @db.VarChar(150)
  province    String?  @db.VarChar(150)
  telephone   String?  @db.VarChar(100)
  email       String?  @db.VarChar(255)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  grossiste    Grossiste?    @relation(fields: [grossisteId], references: [id])
  visitReports VisitReport[]

  @@unique([grossisteId, codeClient])
  @@index([ville])
  @@index([region])
  @@index([nom])
}

// ─── SECTORISATION ─────────────────────────────────────────────
// Depuis SECTORISATION_PAYS_2026.xlsx
model Sector {
  id            String   @id @default(cuid())
  numero        Int
  delegateName  String?  @db.VarChar(255)
  zoneResidence String   @db.VarChar(255)
  peripherie    String?  @db.LongText
  axesMission   String?  @db.LongText
  type          String   @db.VarChar(20)
  createdAt     DateTime @default(now())

  delegates Delegate[]

  @@index([type])
}

// ─── DÉLÉGUÉS ──────────────────────────────────────────────────
model Delegate {
  id           String         @id @default(cuid())
  userId       String         @unique @db.VarChar(30)
  laboratoryId String         @db.VarChar(30)
  sectorId     String?        @db.VarChar(30)
  zone         String         @db.VarChar(255)
  phone        String?        @db.VarChar(50)
  status       DelegateStatus @default(INACTIF)
  lastLat      Float?
  lastLng      Float?
  lastSeen     DateTime?
  createdAt    DateTime       @default(now())

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  laboratory   Laboratory       @relation(fields: [laboratoryId], references: [id])
  sector       Sector?          @relation(fields: [sectorId], references: [id])
  gpsLogs      GPSLog[]
  visitReports VisitReport[]
  planning     WeeklyPlanning[]
}

// ─── GPS LOGS ──────────────────────────────────────────────────
model GPSLog {
  id         String         @id @default(cuid())
  delegateId String         @db.VarChar(30)
  latitude   Float
  longitude  Float
  status     DelegateStatus
  timestamp  DateTime       @default(now())

  delegate Delegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)

  @@index([delegateId])
  @@index([timestamp])
}

// ─── PRODUITS ──────────────────────────────────────────────────
// Depuis STRATEGIE_I_Par_Spécialété.xlsx
model Product {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  group       String   @db.VarChar(50)
  specialty   String   @db.VarChar(100)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([specialty])
  @@index([group])
}

// ─── PLANNING HEBDOMADAIRE ─────────────────────────────────────
// Depuis SEMENIER_ABIDJAN_INOXPHARMA_MAI_2024.xlsx
model WeeklyPlanning {
  id         String   @id @default(cuid())
  delegateId String   @db.VarChar(30)
  weekNumber Int
  zone       String   @db.VarChar(100)
  lundi      String?  @db.LongText
  mardi      String?  @db.LongText
  mercredi   String?  @db.LongText
  jeudi      String?  @db.LongText
  vendredi   String?  @db.LongText
  month      String   @db.VarChar(10)
  createdAt  DateTime @default(now())

  delegate Delegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)

  @@index([zone])
  @@index([month])
}

// ─── RAPPORTS DE VISITE ────────────────────────────────────────
model VisitReport {
  id            String   @id @default(cuid())
  delegateId    String   @db.VarChar(30)
  laboratoryId  String   @db.VarChar(30)
  pharmacyId    String?  @db.VarChar(30)
  doctorName    String   @db.VarChar(255)
  specialty     String?  @db.VarChar(100)
  productsShown String?  @db.Text
  notes         String   @db.LongText
  aiSummary     String?  @db.LongText
  visitDate     DateTime @default(now())
  createdAt     DateTime @default(now())

  delegate   Delegate   @relation(fields: [delegateId], references: [id])
  laboratory Laboratory @relation(fields: [laboratoryId], references: [id])
  pharmacy   Pharmacy?  @relation(fields: [pharmacyId], references: [id])

  @@index([delegateId])
  @@index([visitDate])
}
