generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ─── ENUMS ─────────────────────────────────────────────────────
enum Role {
  SUPER_ADMIN
  ADMIN
  DELEGATE
}

enum DelegateStatus {
  EN_VISITE
  EN_DEPLACEMENT
  EN_PAUSE
  INACTIF
}

// ─── UTILISATEURS ──────────────────────────────────────────────
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  firstName    String    
  lastName     String    
  role         Role      @default(DELEGATE)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  String?   

  createdBy    User?     @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers User[]    @relation("UserCreator")
  adminLabs    AdminLaboratory[]
  delegate     Delegate?
}

// ─── LABORATOIRES ──────────────────────────────────────────────
// lic-pharma | medisure | sigma | ephaco | stallion
model Laboratory {
  id        String   @id @default(cuid())
  name      String   @unique 
  createdAt DateTime @default(now())

  admins    AdminLaboratory[]
  grossLabs GrossisteLaboratory[]
  delegates Delegate[]
  reports   VisitReport[]
}

model AdminLaboratory {
  userId       String 
  laboratoryId String 

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  laboratory   Laboratory @relation(fields: [laboratoryId], references: [id])

  @@id([userId, laboratoryId])
}

// ─── GROSSISTES ────────────────────────────────────────────────
// tedis | copharmed | laborex | dpci
model Grossiste {
  id        String   @id @default(cuid())
  name      String   @unique 
  createdAt DateTime @default(now())

  labs       GrossisteLaboratory[]
  pharmacies Pharmacy[]
}

model GrossisteLaboratory {
  grossisteId  String 
  laboratoryId String 

  grossiste    Grossiste  @relation(fields: [grossisteId], references: [id])
  laboratory   Laboratory @relation(fields: [laboratoryId], references: [id])
  updatedAt    DateTime   @updatedAt
  updatedById  String?    

  stocks GrossisteStock[]

  @@id([grossisteId, laboratoryId])
}

model GrossisteStock {
  id           String   @id @default(cuid())
  grossisteId  String   
  laboratoryId String   
  productName  String   
  quantity     Int      @default(0)
  unitPrice    Float    @default(0)
  month        String   
  updatedAt    DateTime @updatedAt

  grossisteLab GrossisteLaboratory @relation(fields: [grossisteId, laboratoryId], references: [grossisteId, laboratoryId])
}

// ─── PHARMACIES ────────────────────────────────────────────────
// Importées depuis vos 4 fichiers Excel grossistes
model Pharmacy {
  id          String    @id @default(cuid())
  grossisteId String?   
  codeClient  String?   
  nom         String
  pharmacien  String?
  adresse     String?
  ville       String?   
  region      String?   
  province    String?   
  telephone   String?   
  email       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  grossiste    Grossiste?    @relation(fields: [grossisteId], references: [id])
  visitReports VisitReport[]

  @@unique([grossisteId, codeClient])
  @@index([ville])
  @@index([region])
  @@index([nom])
}

// ─── SECTORISATION ─────────────────────────────────────────────
// Depuis SECTORISATION_PAYS_2026.xlsx
model Sector {
  id            String     @id @default(cuid())
  numero        Int
  delegateName  String?
  zoneResidence String
  peripherie    String?    
  axesMission   String?    
  type          String     
  createdAt     DateTime   @default(now())

  delegates     Delegate[]

  @@index([type])
}

// ─── DÉLÉGUÉS ──────────────────────────────────────────────────
model Delegate {
  id           String         @id @default(cuid())
  userId       String         @unique 
  laboratoryId String         
  sectorId     String?        
  zone         String
  phone        String?        
  status       DelegateStatus @default(INACTIF)
  lastLat      Float?
  lastLng      Float?
  lastSeen     DateTime?
  createdAt    DateTime       @default(now())

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  laboratory   Laboratory     @relation(fields: [laboratoryId], references: [id])
  sector       Sector?        @relation(fields: [sectorId], references: [id])
  gpsLogs      GPSLog[]
  visitReports VisitReport[]
  planning     WeeklyPlanning[]
}

// ─── GPS LOGS ──────────────────────────────────────────────────
model GPSLog {
  id         String         @id @default(cuid())
  delegateId String         
  latitude   Float
  longitude  Float
  status     DelegateStatus
  timestamp  DateTime       @default(now())

  delegate   Delegate       @relation(fields: [delegateId], references: [id], onDelete: Cascade)

  @@index([delegateId])
  @@index([timestamp])
}

// ─── PRODUITS ──────────────────────────────────────────────────
// Depuis STRATEGIE_I_Par_Spécialété.xlsx
model Product {
  id          String   @id @default(cuid())
  name        String   @unique 
  group       String   
  specialty   String   
  description String?  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([specialty])
  @@index([group])
}

// ─── PLANNING HEBDOMADAIRE ─────────────────────────────────────
// Depuis SEMENIER_ABIDJAN_INOXPHARMA_MAI_2024.xlsx
model WeeklyPlanning {
  id         String   @id @default(cuid())
  delegateId String   
  weekNumber Int
  zone       String   
  lundi      String?  
  mardi      String?  
  mercredi   String?  
  jeudi      String?  
  vendredi   String?  
  month      String   
  createdAt  DateTime @default(now())

  delegate   Delegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)

  @@index([zone])
  @@index([month])
}

// ─── RAPPORTS DE VISITE ────────────────────────────────────────
model VisitReport {
  id            String     @id @default(cuid())
  delegateId    String     
  laboratoryId  String     
  pharmacyId    String?    
  doctorName    String
  specialty     String?    
  productsShown String?    
  notes         String     
  aiSummary     String?    
  visitDate     DateTime   @default(now())
  createdAt     DateTime   @default(now())

  delegate      Delegate   @relation(fields: [delegateId], references: [id])
  laboratory    Laboratory @relation(fields: [laboratoryId], references: [id])
  pharmacy      Pharmacy?  @relation(fields: [pharmacyId], references: [id])

  @@index([delegateId])
  @@index([visitDate])
}
