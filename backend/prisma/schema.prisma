generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String
  firstName         String
  lastName          String
  role              Role               @default(DELEGATE)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdById       String?
  activeSessions    ActiveSession?
  adminLabs         AdminLaboratory[]
  delegate          Delegate?
  loginHistory      LoginHistory[]
  receivedMessages  Message[]          @relation("ReceivedMessages")
  sentMessages      Message[]          @relation("SentMessages")
  pushSubscriptions PushSubscription[]
  salesReports      SalesReport[]
  createdBy         User?              @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers      User[]             @relation("UserCreator")
  strategies        Strategy[]
  reportRecipient             ReportRecipient?
  emailSchedules              EmailSchedule[]
  emailScheduleRecipients     EmailScheduleRecipient[]
  avatar String?
}

model ActiveSession {
  id         String   @id @default(cuid())
  userId     String   @unique
  token      String
  deviceInfo String?
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  deviceInfo String?
  ipAddress  String?
  success    Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
}

model Laboratory {
  id           String                @id @default(cuid())
  name         String                @unique
  color        String?
  emoji        String?
  description  String?
  createdAt    DateTime              @default(now())
  admins       AdminLaboratory[]
  delegates    Delegate[]
  grossLabs    GrossisteLaboratory[]
  salesReports SalesReport[]
  reports      VisitReport[]
  strategies   Strategy[]
}

model AdminLaboratory {
  userId       String
  laboratoryId String
  laboratory   Laboratory @relation(fields: [laboratoryId], references: [id])
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, laboratoryId])
}

model Grossiste {
  id         String                @id @default(cuid())
  name       String                @unique
  createdAt  DateTime              @default(now())
  labs       GrossisteLaboratory[]
  pharmacies Pharmacy[]
}

model GrossisteLaboratory {
  grossisteId  String
  laboratoryId String
  updatedAt    DateTime         @updatedAt
  updatedById  String?
  grossiste    Grossiste        @relation(fields: [grossisteId], references: [id])
  laboratory   Laboratory       @relation(fields: [laboratoryId], references: [id])
  stocks       GrossisteStock[]

  @@id([grossisteId, laboratoryId])
}

model GrossisteStock {
  id           String              @id @default(cuid())
  grossisteId  String
  laboratoryId String
  productName  String
  quantity     Int                 @default(0)
  unitPrice    Float               @default(0)
  month        String
  updatedAt    DateTime            @updatedAt
  grossisteLab GrossisteLaboratory @relation(fields: [grossisteId, laboratoryId], references: [grossisteId, laboratoryId])
}

model Pharmacy {
  id           String        @id @default(cuid())
  grossisteId  String?
  codeClient   String?
  nom          String
  pharmacien   String?
  adresse      String?
  ville        String?
  region       String?
  province     String?
  telephone    String?
  email        String?
  latitude     Float?
  longitude    Float?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  grossiste    Grossiste?    @relation(fields: [grossisteId], references: [id])
  visitReports VisitReport[]

  @@unique([grossisteId, codeClient])
}

model Sector {
  id            String     @id @default(cuid())
  numero        Int
  delegateName  String?
  zoneResidence String
  peripherie    String?
  axesMission   String?
  type          String
  createdAt     DateTime   @default(now())
  delegates     Delegate[]
}

model Delegate {
  id           String              @id @default(cuid())
  userId       String              @unique
  laboratoryId String
  sectorId     String?
  zone         String
  phone        String?
  status       DelegateStatus      @default(INACTIF)
  lastLat      Float?
  lastLng      Float?
  lastSeen     DateTime?
  createdAt    DateTime            @default(now())
  laboratory   Laboratory          @relation(fields: [laboratoryId], references: [id])
  sector       Sector?             @relation(fields: [sectorId], references: [id])
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  objectives   DelegateObjective[]
  gpsLogs      GPSLog[]
  checkIns     CheckIn[]
  visitReports VisitReport[]
  planning     WeeklyPlanning[]
}

model GPSLog {
  id         String         @id @default(cuid())
  delegateId String
  latitude   Float
  longitude  Float
  status     DelegateStatus
  timestamp  DateTime       @default(now())
  delegate   Delegate       @relation(fields: [delegateId], references: [id], onDelete: Cascade)
}

model CheckIn {
  id         String   @id @default(cuid())
  delegateId String
  latitude   Float
  longitude  Float
  placeName  String
  timestamp  DateTime @default(now())
  delegate   Delegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)
}

model WeeklyPlanning {
  id         String   @id @default(cuid())
  delegateId String
  weekNumber Int
  zone       String
  lundi      String?
  mardi      String?
  mercredi   String?
  jeudi      String?
  vendredi   String?
  month      String
  createdAt  DateTime @default(now())
  delegate   Delegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)
}

model DelegateObjective {
  id               String   @id @default(cuid())
  delegateId       String
  month            String
  year             Int
  targetVisits     Int      @default(0)
  targetReports    Int      @default(0)
  targetPharmacies Int      @default(0)
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  delegate         Delegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)

  @@unique([delegateId, month, year])
}

model VisitReport {
  id            String     @id @default(cuid())
  delegateId    String
  laboratoryId  String
  pharmacyId    String?
  doctorName    String
  specialty     String?
  productsShown String?
  notes         String
  aiSummary     String?
  visitDate     DateTime   @default(now())
  createdAt     DateTime   @default(now())
  delegate      Delegate   @relation(fields: [delegateId], references: [id])
  laboratory    Laboratory @relation(fields: [laboratoryId], references: [id])
  pharmacy      Pharmacy?  @relation(fields: [pharmacyId], references: [id])
}

model SalesReport {
  id            String            @id @default(cuid())
  adminId       String
  laboratoryId  String
  month         String
  year          Int
  status        SalesReportStatus @default(DRAFT)
  submittedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  targetCA      Float             @default(0)
  targetCASetAt DateTime?
  admin         User              @relation(fields: [adminId], references: [id])
  laboratory    Laboratory        @relation(fields: [laboratoryId], references: [id])
  lines         SalesReportLine[]
}

model SalesReportLine {
  id             String      @id @default(cuid())
  reportId       String
  itemNumber     Int
  designation    String
  pght           Float       @default(0)
  copharmedStock Float       @default(0)
  copharmedVente Float       @default(0)
  copharmedS     Float       @default(0)
  copharmedV     Float       @default(0)
  laborexStock   Float       @default(0)
  laborexVente   Float       @default(0)
  laborexS       Float       @default(0)
  laborexV       Float       @default(0)
  tedisStock     Float       @default(0)
  tedisVente     Float       @default(0)
  tedisS         Float       @default(0)
  tedisV         Float       @default(0)
  dpciStock      Float       @default(0)
  dpciVente      Float       @default(0)
  dpciS          Float       @default(0)
  dpciV          Float       @default(0)
  report         SalesReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(cuid())
  name        String   @unique
  group       String
  specialty   String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DELEGATE
}

enum DelegateStatus {
  EN_VISITE
  EN_DEPLACEMENT
  EN_PAUSE
  INACTIF
}

enum SalesReportStatus {
  DRAFT
  SUBMITTED
}

model Strategy {
  id            String    @id @default(cuid())
  title         String
  description   String?
  targetProduct String?
  targetZone    String?
  startDate     DateTime?
  endDate       DateTime?
  laboratoryId  String
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  laboratory    Laboratory @relation(fields: [laboratoryId], references: [id])
  createdBy     User       @relation(fields: [createdById], references: [id])
}

model ReportConfig {
  id         String            @id @default(cuid())
  sendHour   Int               @default(9)
  sendMinute Int               @default(30)
  isActive   Boolean           @default(true)
  recipients ReportRecipient[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model ReportRecipient {
  id             String       @id @default(cuid())
  userId         String       @unique
  reportConfigId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportConfig   ReportConfig @relation(fields: [reportConfigId], references: [id], onDelete: Cascade)
}

model EmailSchedule {
  id          String                   @id @default(cuid())
  hour        Int                      @default(9)
  minute      Int                      @default(30)
  isActive    Boolean                  @default(true)
  recipients  EmailScheduleRecipient[]
  createdById String
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  createdBy   User                     @relation(fields: [createdById], references: [id])
}

model EmailScheduleRecipient {
  id         String        @id @default(cuid())
  scheduleId String
  userId     String
  schedule   EmailSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, userId])
}
